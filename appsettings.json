{
  "AdSettings": {
    "ForestRootDomain": "lab.local",
    "ForestChildDomain": [
      "new.lab.local",
      "old.lab.local"
    ],
    "AccessControl": {
      "GeneralAccessGroups": [
        "GG-Standard-Users"
      ],
      "HighPrivilegeGroups": [
        "GG-Server-Admins"
      ]
    },
    "Provisioning": {
      "ServiceAccountUser": "LAB\\svc_adweb",
      "ServiceAccountPassword": "CHANGE_ME_SECURELY",
      "DefaultUserOuFormat": "OU=Users,{domain-components}",
      "AdminUserOuFormat": "OU=PrivilegedUsers,{domain-components}",
      "OptionalGeneralAccessGroup": [
        "GG-Standard-Users",
        "GG-Share-DeptA",
        "GG-Share-DeptB"
      ],
      "OptionalPrivilegeGroup": [
        "GG-Server-Admins",
        "GG-DA-Assist",
        "GG-Backup-Operators"
      ],
      "SearchBaseOus": [
        "OU=Users,{domain-components}"
      ]
    },
    "BirthdateAttribute": "extensionAttribute1",
    "PrivilegedAccountValidityDays": 30,
    "PasswordPolicy": {
      "Standard": {
        "Length": 12,
        "IncludeLetters": true,
        "IncludeDigits": true,
        "IncludeSpecials": true,
        "AllowedSpecials": "!@#$%^&*()-_=+[]{}"
      },
      "Admin": {
        "Length": 8,
        "IncludeLetters": true,
        "IncludeDigits": true,
        "IncludeSpecials": false,
        "AllowedSpecials": ""
      }
    },
    "Security": {
      "Csrf": {
        "Enabled": true,
        "HeaderName": "X-CSRF-Token"
      },
      "Cookies": {
        "SameSite": "Strict",
        "Secure": true,
        "HttpOnly": true
      },
      "Session": {
        "IdleTimeoutMinutes": 20,
        "AbsoluteTimeoutMinutes": 240,
        "DeviceFingerprint": true
      }
    },
    "Audit": {
      "LocalFile": {
        "Enabled": true,
        "Path": "logs/audit.log",
        "Rolling": "Daily"
      },
      "Syslog": {
        "Enabled": false,
        "Host": "127.0.0.1",
        "Port": 514,
        "Protocol": "UDP",
        "Format": "RFC5424"
      },
      "CEF": {
        "Enabled": false,
        "Endpoint": ""
      }
    },
    "Health": {
      "DomainControllers": [
        {
          "Domain": "lab.local",
          "Host": "dc01.lab.local"
        },
        {
          "Domain": "new.lab.local",
          "Host": "dc01.new.lab.local"
        }
      ],
      "LdapLatencyWarnMs": 500,
      "LdapLatencyCritMs": 1500,
      "ServiceAccountLockoutWarnThreshold": 1,
      "LogDiskPath": "logs",
      "LogDiskMinFreeMB": 1024
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning", 
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}