<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments="ADWebManager.dll" stdoutLogEnabled="false" hostingModel="InProcess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
      </environmentVariables>
    </aspNetCore>

    <security>
      <authentication>
        <anonymousAuthentication enabled="true" />
        <windowsAuthentication enabled="true" />
      </authentication>
    </security>

    <rewrite>
      <rules>
        <rule name="AdminWindowsAuth" stopProcessing="true">
          <match url="^admin(.*)" />
          <action type="None" />
          <conditions>
          </conditions>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>